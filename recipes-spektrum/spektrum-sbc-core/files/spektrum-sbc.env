SPEKTRUM_ENABLE_RECOVERY_AP=1
SPEKTRUM_STA_FAIL_THRESHOLD=6
SPEKTRUM_RECOVERY_AP_WINDOW_SECONDS=180
SPEKTRUM_I2C_PORT=0
SPEKTRUM_I2C_ADDRESS=0x3C
SPEKTRUM_OLED_WIDTH=128
SPEKTRUM_OLED_HEIGHT=32
SPEKTRUM_OLED_INTERVAL=2
SPEKTRUM_OLED_PAGE_SECONDS=4
SPEKTRUM_OLED_ROTATE=0
