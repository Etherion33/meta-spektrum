[Unit]
Description=Spektrum Tailscale one-time enrollment
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service

[Service]
Type=oneshot
EnvironmentFile=-/etc/spektrum/spektrum.env
ExecStart=/usr/bin/bash -lc '${SPEKTRUM_ROOT:-/opt/spektrum}/scripts/sbc/tailscale_enroll.sh'
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
