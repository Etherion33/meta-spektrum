From: Spektrum <devnull@spektrum.local>
Subject: [PATCH] arm64: dts: meson-g12a-radxa-zero: enable i2c3 and LED
Upstream-Status: Inappropriate [product-specific hardware configuration]

--- a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
@@ -21,6 +21,17 @@
 		stdout-path = "serial0:115200n8";
 	};
 
+	leds {
+		compatible = "gpio-leds";
+
+		led-green {
+			label = "radxa-zero:green";
+			gpios = <&gpio_ao GPIOAO_10 GPIO_ACTIVE_HIGH>;
+			linux,default-trigger = "heartbeat";
+			default-state = "on";
+		};
+	};
+
 	memory@0 {
 		device_type = "memory";
 		reg = <0x0 0x0 0x0 0x40000000>;
@@ -365,6 +376,12 @@
 	vqmmc-supply = <&vcc_1v8>;
 };
 
+&i2c3 {
+	status = "okay";
+	pinctrl-0 = <&i2c3_sck_a_pins>, <&i2c3_sda_a_pins>;
+	pinctrl-names = "default";
+};
+
 &tdmif_b {
 	status = "okay";
 };
